:8080 {
	encode gzip

	# per-session ttyd mounts (ttyd serves at its base path)
	handle_path /s/codex* {
		reverse_proxy localhost:7682
	}
	handle_path /s/wave* {
		reverse_proxy localhost:7683
	}
	handle_path /s/issue12* {
		reverse_proxy localhost:7684
	}

	# hangar backend REST API
	handle_path /api/* {
		reverse_proxy localhost:3000
	}

	# hangar backend WebSocket (preserve /ws/ prefix)
	handle /ws/* {
		reverse_proxy localhost:3000
	}

	# Phase 2 xterm.js terminal UI
	handle_path /v2* {
		root * /home/george/Documents/hangar/web/v2
		try_files {path} /index.html
		file_server
	}

	# static dashboard
	handle {
		root * /home/george/Documents/hangar/web
		try_files {path} /index.html
		file_server
	}

	log {
		output file /var/log/caddy/dashboard.log
		format console
	}
}
