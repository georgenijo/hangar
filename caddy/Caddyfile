:8080 {
	encode gzip

	# API proxy
	handle /api/* {
		reverse_proxy localhost:3000
	}

	# WebSocket proxy
	handle /ws/* {
		reverse_proxy localhost:3000
	}

	# ntfy push relay
	handle_path /ntfy/* {
		reverse_proxy localhost:2586
	}

	# SvelteKit SPA dashboard
	handle {
		root * /home/george/Documents/hangar/frontend/build
		try_files {path} /index.html
		file_server
	}

	log {
		output file /var/log/caddy/dashboard.log
		format console
	}
}
