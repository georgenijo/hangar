[Unit]
Description=ttyd for tmux session: codex
After=network.target
Requires=network.target

[Service]
Type=simple
User=george
Group=george
Environment=TERM=xterm-256color
ExecStart=/usr/bin/ttyd -p 7682 -W -t titleFixed=codex -t fontSize=13 tmux attach -t codex
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
