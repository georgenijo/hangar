[Unit]
Description=ttyd for tmux session: wave
After=network.target
Requires=network.target

[Service]
Type=simple
User=george
Group=george
Environment=TERM=xterm-256color
ExecStart=/usr/bin/ttyd -p 7683 -W -t titleFixed=wave -t fontSize=13 tmux attach -t wave
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
